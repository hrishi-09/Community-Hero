# Community Hero - Kolkata
# Copy this to .env and fill in your values

# ── Database ──────────────────────────────────────────
# Render PostgreSQL connection string (auto-set on Render)
DATABASE_URL=postgresql://postgres:password@localhost:5432/community_hero

# ── Security ──────────────────────────────────────────
SECRET_KEY=change-this-to-a-long-random-string-in-production

# ── SMS Provider ──────────────────────────────────────
# Choose: twilio | msg91
# Leave blank for dev mode (OTP printed to console)
SMS_PROVIDER=twilio

# Twilio (get from twilio.com)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# MSG91 (alternative Indian SMS, get from msg91.com)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=CMHERO
MSG91_TEMPLATE_ID=

# ── Environment ───────────────────────────────────────
ENV=production
PORT=8000
